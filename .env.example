# Copy this file to .env.local and fill in your own values.
# .env.local is git-ignored — never commit real keys.
#
# Both are safe to expose in the browser bundle: the anon key is protected by
# Row Level Security (every table enforces auth.uid() = user_id). The private
# Gemini key lives ONLY as a Supabase Edge Function secret, never here.

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Your Supabase project "anon" / public key (Project Settings → API)
VITE_SUPABASE_ANON_KEY=

# Only needed for `npm run db:backup` (never shipped to the browser).
# "Session pooler" connection string from Supabase dashboard → Connect,
# with your database password filled in. CONTAINS A SECRET — .env.local only.
SUPABASE_DB_URL=
